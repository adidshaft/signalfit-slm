ay's mood\" are invented and ignore /context/today/resting_pulse_state and /context/today/sleep_hours.","evidence":[{"kind":"answer_quote","quote":"Motivation, weather, hydration, genetics, and yesterday's mood"},{"kind":"context_pointer","pointer":"/context/today/resting_pulse_state","observed_value":"elevated"},{"kind":"context_pointer","pointer":"/context/today/sleep_hours","observed_value":5.9}]},"D3":{"pass":false,"reason_code":"omitted_required","explanation":"The claim \"Your composite looks excellent\" omits the required statement that recovery is unavailable at /context/data_quality/missing_fields.","evidence":[{"kind":"answer_quote","quote":"Your composite looks excellent"},{"kind":"context_pointer","pointer":"/context/data_quality/missing_fields","observed_value":["recovery_score"]}]},"D4":{"pass":false,"reason_code":"wrong_count","explanation":"The alternatives \"sprint, lift, swim, or add a long ride\" provide four next actions rather than exactly one.","evidence":[{"kind":"answer_quote","quote":"sprint, lift, swim, or add a long ride"}]}},"category_pass":false}
